#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

printf '%s\n' 'Running local CI checks before commit...'

if command -v make >/dev/null 2>&1; then
  exec make pre-commit
fi

python_cmd="${PYTHON:-python3}"
if ! command -v "$python_cmd" >/dev/null 2>&1; then
  python_cmd=python
fi

ruff_cmd="${RUFF:-ruff}"

"$python_cmd" -m py_compile src/main.py src/nodpi/*.py tests/*.py

if command -v "$ruff_cmd" >/dev/null 2>&1; then
  "$ruff_cmd" check .
elif "$python_cmd" -m ruff --version >/dev/null 2>&1; then
  "$python_cmd" -m ruff check .
else
  printf '%s\n' "ruff is required for linting. Install dependencies with: make install-deps" >&2
  exit 1
fi

"$python_cmd" -m unittest discover -s tests -v
